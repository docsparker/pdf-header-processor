{
  "replacements": {
    "^Draft.*": "Final Document",
    "Company A": "Company B",
    "Version \\d+\.\\d+": "Version 3.0"
  },
  "output_dir": "./output",
  "num_workers": 8,
  "dry_run": false,
  "preserve_formatting": true,
  "lines_to_check": 10,
  "case_sensitive": false,
  "use_regex": true,
  "backup_originals": true,
  "log_level": "DEBUG"
}
